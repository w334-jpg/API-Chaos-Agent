# ── Store ──────────────────────────────────────────
STORE_MAX_SCHEMAS=1000
STORE_MAX_SCENARIOS=1000
STORE_MAX_EXECUTIONS=1000
STORE_MAX_REPORTS=1000
STORE_TTL_SECONDS=3600
STORE_BACKEND=memory
STORE_SQLITE_PATH=data/chaos_agent.db

# ── Execution Engine ───────────────────────────────
EXEC_MAX_BURST_REQUESTS=500
EXEC_BACKOFF_BASE=1.0
EXEC_BACKOFF_MAX=30.0
EXEC_JITTER_FACTOR=0.1
EXEC_MAX_DELAY_SECONDS=2.0

# ── LLM Router ─────────────────────────────────────
LLM_CACHE_DIR=/tmp/llm_router_cache
LLM_CACHE_TTL=3600
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_OLLAMA_TIMEOUT=120
LLM_CLOUD_TIMEOUT=60
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_RESET_TIMEOUT=60

# ── Server ─────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_MAX_REQUEST_BODY_SIZE=10485760
SERVER_MAX_UPLOAD_SIZE=10485760
SERVER_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Auth ───────────────────────────────────────────
AUTH_ENABLED=false
AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Rate Limit ─────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Logging ────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_JSON_INDENT=2
