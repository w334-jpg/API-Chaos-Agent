# API Chaos Agent - Environment Configuration
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ─── LLM Configuration ───────────────────────────────────
# Cloud LLM API keys (optional - works with rule engine + Ollama without these)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model selection
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Authentication ───────────────────────────────────────
AUTH_ENABLED=false
AUTH_SECRET_KEY=change-me-in-production-use-a-strong-key
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ─── Store ────────────────────────────────────────────────
STORE_BACKEND=memory
STORE_SQLITE_PATH=data/chaos_agent.db
STORE_TTL_SECONDS=3600

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
